Options -MultiViews
RewriteEngine On

# 1. Prevent direct browser access to .php files for security
# But allow the server to process them internally (like index.php)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.php\ HTTP/
RewriteRule ^.*\.php$ - [F,L]

# 2. Allow existing files and directories to be accessed directly
# This covers CSS, JS, Images, and existing HTML files
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Route everything else to index.php
# This enables clean URLs like /login, /doctors, etc.
RewriteRule ^(.*)$ index.php [L,QSA]
